datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Reporter {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  email     String?    @db.VarChar(255)
  phone     String?    @db.VarChar(50)
  role      String     @default("civilian") // civilian, operator, first_responder, sensor
  metadata  Json?
  incidents Incident[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role])
}

model Incident {
  id                String           @id // E.g., #INC-4092 or UUID
  version           Int              @default(1)
  status            String           @default("pending") // pending, in-progress, dispatched, resolved
  source            String // text, audio, image, video, webhook, bulk
  incidentType      String           @default("other")
  rawContent        String           @db.Text
  structuredDesc    String           @db.Text
  confidence        Float            @default(0.0)
  lat               Float?
  lng               Float?
  locationName      String?          @db.VarChar(255)
  extractedEntities Json // Locations, Hazards, People, Vehicles, Organizations
  agentHistory      Json // History of reasoning & confidence across pipeline
  auditTrail        Json // Timeline tracking versions & edits
  metadata          Json?
  tags              String[]
  reporterId        String?          @db.Uuid
  reporter          Reporter?        @relation(fields: [reporterId], references: [id])
  media             Media[]
  auditLogs         AuditLog[]
  agentExecutions   AgentExecution[]
  riskAssessment    RiskAssessment?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([incidentType])
  @@index([createdAt])
}

model Media {
  id         String    @id @default(uuid()) @db.Uuid
  url        String    @db.Text // Firebase Storage signed url
  type       String // image, audio, video
  metadata   Json?
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([incidentId])
}

model AgentExecution {
  id           String    @id @default(uuid()) @db.Uuid
  agentName    String // data-dispatcher, risk-evaluator, field-validator, etc.
  incidentId   String
  incident     Incident  @relation(fields: [incidentId], references: [id])
  status       String // success, failed
  confidence   Float
  reasoning    String    @db.Text
  outputData   Json
  errorMessage String?   @db.Text
  startedAt    DateTime  @default(now())
  completedAt  DateTime  @default(now())

  @@index([incidentId])
  @@index([agentName])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
  changedBy  String // Operator ID, Clerk ID, or system
  action     String // create, update_status, enrich_entities, etc.
  oldValue   Json?
  newValue   Json
  createdAt  DateTime @default(now())

  @@index([incidentId])
}

model SystemEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventName String // IncidentCreated, IncidentEnriched, etc.
  payload   Json
  status    String // published, failed
  createdAt DateTime @default(now())

  @@index([eventName])
}

model WebhookLog {
  id           String   @id @default(uuid()) @db.Uuid
  source       String // twilio, pagerduty, generic, etc.
  payload      Json
  statusCode   Int
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model RiskAssessment {
  id                     String                @id @default(uuid()) @db.Uuid
  incidentId             String                @unique
  incident               Incident              @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  severity               String                // LOW, MEDIUM, HIGH, CRITICAL
  priority               String                // LOW, MEDIUM, HIGH, CRITICAL
  overallRiskScore       Float                 // Normalized score, e.g., 0.0 - 1.0 or 0 - 100
  confidence             Float                 // Confidence score, 0.0 - 1.0
  reasoning              String                @db.Text
  isProtocolZeroTriggered Boolean              @default(false)
  threatPredictions      ThreatPrediction[]
  severityHistory        SeverityHistory[]
  priorityHistory        PriorityHistory[]
  reasoningLogs          ReasoningLog[]
  protocolZeroRequests   ProtocolZeroRequest[]
  commanderOverrides     CommanderOverride[]
  createdAt              DateTime              @default(now())

  updatedAt              DateTime              @updatedAt

  @@index([incidentId])
  @@index([severity])
  @@index([priority])
}

model ThreatPrediction {
  id                 String         @id @default(uuid()) @db.Uuid
  riskAssessmentId   String         @db.Uuid
  riskAssessment     RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  threatType         String         // E.g., structural_collapse, wildfire_spread, toxic_leak
  probability        Float          // 0.0 - 1.0
  impact             String         // LOW, MEDIUM, HIGH, CRITICAL
  estimatedTimeframe String         // E.g., "15m", "1h", "immediate"
  confidence         Float          // 0.0 - 1.0
  createdAt          DateTime       @default(now())

  @@index([riskAssessmentId])
  @@index([threatType])
}

model SeverityHistory {
  id               String         @id @default(uuid()) @db.Uuid
  riskAssessmentId String         @db.Uuid
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  severity         String         // LOW, MEDIUM, HIGH, CRITICAL
  score            Float
  reason           String         @db.Text
  changedBy        String         // User ID or system agent identifier
  createdAt        DateTime       @default(now())

  @@index([riskAssessmentId])
}

model PriorityHistory {
  id               String         @id @default(uuid()) @db.Uuid
  riskAssessmentId String         @db.Uuid
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  priority         String         // LOW, MEDIUM, HIGH, CRITICAL
  score            Float
  reason           String         @db.Text
  changedBy        String         // User ID or system agent identifier
  createdAt        DateTime       @default(now())

  @@index([riskAssessmentId])
}

model ProtocolZeroRequest {
  id               String            @id @default(uuid()) @db.Uuid
  riskAssessmentId String            @db.Uuid
  riskAssessment   RiskAssessment    @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  status           String            @default("pending") // pending, approved, rejected, modified, escalated
  requestedBy      String            // User ID or Agent ID
  reason           String            @db.Text
  approvedBy       String?           // Operator ID who authorized it
  actionedAt       DateTime?
  approvalRequests ApprovalRequest[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([riskAssessmentId])
  @@index([status])
}

model ApprovalRequest {
  id                    String                @id @default(uuid()) @db.Uuid
  protocolZeroRequestId String                @db.Uuid
  protocolZeroRequest   ProtocolZeroRequest   @relation(fields: [protocolZeroRequestId], references: [id], onDelete: Cascade)
  commanderId           String?
  status                String                @default("pending") // pending, approved, rejected, modified, escalated, expired
  timeoutAt             DateTime
  approvalDecisions     ApprovalDecision[]
  approvalHistories     ApprovalHistory[]
  escalationHistories   EscalationHistory[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([protocolZeroRequestId])
  @@index([status])
}

model ApprovalDecision {
  id                String          @id @default(uuid()) @db.Uuid
  approvalRequestId String          @db.Uuid
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  commanderId       String
  decision          String          // approved, rejected, modified
  justification     String          @db.Text
  modificationPayload Json?
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId])
  @@index([commanderId])
}

model CommanderOverride {
  id               String         @id @default(uuid()) @db.Uuid
  riskAssessmentId String         @db.Uuid
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  commanderId      String
  reason           String         @db.Text
  overriddenSeverity String?
  overriddenPriority String?
  createdAt        DateTime       @default(now())

  @@index([riskAssessmentId])
}

model ApprovalHistory {
  id                String          @id @default(uuid()) @db.Uuid
  approvalRequestId String          @db.Uuid
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  action            String          // created, approved, rejected, modified, escalated, reminder_sent
  actor             String
  notes             String?         @db.Text
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId])
}

model EscalationHistory {
  id                String          @id @default(uuid()) @db.Uuid
  approvalRequestId String          @db.Uuid
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  previousCommanderId String?
  escalatedToCommanderId String
  reason            String          @db.Text
  createdAt         DateTime        @default(now())

  @@index([approvalRequestId])
}


model ReasoningLog {
  id               String         @id @default(uuid()) @db.Uuid
  riskAssessmentId String         @db.Uuid
  riskAssessment   RiskAssessment @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)
  agentName        String         // risk-evaluator, threat-predictor, protocol-zero-engine
  inputPayload     Json
  outputPayload    Json
  confidence       Float
  reasoning        String         @db.Text
  createdAt        DateTime       @default(now())

  @@index([riskAssessmentId])
  @@index([agentName])
}

